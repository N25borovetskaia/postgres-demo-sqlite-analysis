   "source": [
    "import os\n",
    "import re\n",
    "import gzip\n",
    "import shutil\n",
    "import sqlite3\n",
    "\n",
    "import pandas as pd"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "0d505420-a68f-4b75-aa4f-b765627aca0e",
   "metadata": {},
   "source": [
    "## 1. Загружаем дамп демо-базы\n",
    "\n",
    "Файл скачан вручную через браузер и загружен в Jupyter через файловый менеджер."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "ed6172bc-7ecd-4998-bb4e-2664e7195031",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "139299795 байт\n"
     ]
    }
   ],
   "source": [
    "GZ_PATH = \"demo-20250901-3m.sql.gz\"\n",
    "SQL_PATH = \"demo-20250901-3m.sql\"\n",
    "\n",
    "print(os.path.getsize(GZ_PATH), \"байт\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "5d524d5b-f7fd-4915-baa6-f782d3060cfb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Файл целый"
     ]
    }
   ],
   "source": [
    "try:\n",
    "    with gzip.open(GZ_PATH, \"rb\") as f:\n",
    "        f.read()\n",
    "    print(\"Файл целый")\n",
    "except EOFError:\n",
    "    print(\"Файл поврежден")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "699963a4-5b56-4ba1-bd0c-11c845da7553",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Распаковано: demo-20250901-3m.sql 499248296 байт\n"
     ]
    }
   ],
   "source": [
    "if os.path.exists(SQL_PATH):\n",
    "    os.remove(SQL_PATH)\n",
    "\n",
    "with gzip.open(GZ_PATH, \"rb\") as f_in, open(SQL_PATH, \"wb\") as f_out:\n",
    "    shutil.copyfileobj(f_in, f_out)\n",
    "\n",
    "print(\"Распаковано:\", SQL_PATH, os.path.getsize(SQL_PATH), \"байт\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c4b49415-a65c-47c2-85cf-d84c2f773f44",
   "metadata": {},
   "source": [
    "## 2. Загружаем данные из дампа сразу в SQLite\n",
    "\n",
    "В этом окружении нет Docker и PostgreSQL, поэтому дамп читается напрямую:\n",
    "находим блоки COPY таблица (колонки) FROM stdin и построчно вставляем\n",
    "данные в SQLite, без промежуточного PostgreSQL."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "33a12765-fd47-454c-9173-091d8aacf0de",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Загружена таблица airplanes_data\n",
      "Загружена таблица airports_data\n",
      "Загружена таблица boarding_passes\n",
      "Загружена таблица bookings\n",
      "Загружена таблица flights\n",
      "Загружена таблица routes\n",
      "Загружена таблица seats\n",
      "Загружена таблица segments\n",
      "Загружена таблица tickets\n",
      "Готово: demo.sqlite\n"
     ]
    }
   ],
   "source": [
    "SQLITE_PATH = \"demo.sqlite\"\n",
    "\n",
    "if os.path.exists(SQLITE_PATH):\n",
    "    os.remove(SQLITE_PATH)\n",
    "\n",
    "conn = sqlite3.connect(SQLITE_PATH)\n",
    "cur = conn.cursor()\n",
    "\n",
    "copy_re = re.compile(r'^COPY\\s+bookings\\.(\\w+)\\s*\\(([^)]*)\\)\\s+FROM stdin;')\n",
    "\n",
    "current_table = None\n",
    "current_cols = None\n",
    "rows_buffer = []\n",
    "BATCH = 5000\n",
    "\n",
    "def flush(table, cols, rows):\n",
    "    if not rows:\n",
    "        return\n",
    "    placeholders = \", \".join([\"?\"] * len(cols))\n",
    "    cur.executemany(f'INSERT INTO \"{table}\" VALUES ({placeholders})', rows)\n",
    "    conn.commit()\n",
    "\n",
    "with open(SQL_PATH, \"r\", encoding=\"utf-8\") as f:\n",
    "    for line in f:\n",
    "        if current_table is None:\n",
    "            m = copy_re.match(line)\n",
    "            if m:\n",
    "                current_table = m.group(1)\n",
    "                current_cols = [c.strip() for c in m.group(2).split(\",\")]\n",
    "                col_defs = \", \".join(f'\"{c}\" TEXT' for c in current_cols)\n",
    "                cur.execute(f'DROP TABLE IF EXISTS \"{current_table}\"')\n",
    "                cur.execute(f'CREATE TABLE \"{current_table}\" ({col_defs})')\n",
    "                rows_buffer = []\n",
    "        else:\n",
    "            if line.startswith(\"\\\\.\"):\n",
    "                flush(current_table, current_cols, rows_buffer)\n",
    "                print(\"Загружена таблица\", current_table)\n",
    "                current_table = None\n",
    "                current_cols = None\n",
    "                rows_buffer = []\n",
    "            else:\n",
    "                values = line.rstrip(\"\\n\").split(\"\\t\")\n",
    "                values = [None if v == \"\\\\N\" else v for v in values]\n",
    "                rows_buffer.append(values)\n",
    "                if len(rows_buffer) >= BATCH:\n",
    "                    flush(current_table, current_cols, rows_buffer)\n",
    "                    rows_buffer = []\n",
    "\n",
    "conn.close()\n",
    "print(\"Готово:\", SQLITE_PATH)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "1f9582e1-e7d6-4ef5-81a3-66fad55d538b",
   "metadata": {},
   "source": [
    "## 3. Ищем самолеты без рейсов\n",
    "\n",
    "Через LEFT JOIN таблиц airplanes_data, routes и flights находим самолеты,\n",
    "для которых нет ни одного рейса. Поле model хранится как jsonb-строка с\n",
    "переводами, русское название достается через json_extract."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "902be4e0-b280-48c0-9c1f-c29f91676bc4",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/html": [
       "<div>\n",
       "<style scoped>\n",
       "    .dataframe tbody tr th:only-of-type {\n",
       "        vertical-align: middle;\n",
       "    }\n",
       "\n",
       "    .dataframe tbody tr th {\n",
       "        vertical-align: top;\n",
       "    }\n",
       "\n",
       "    .dataframe thead th {\n",
       "        text-align: right;\n",
       "    }\n",
       "</style>\n",
       "<table border=\"1\" class=\"dataframe\">\n",
       "  <thead>\n",
       "    <tr style=\"text-align: right;\">\n",
       "      <th></th>\n",
       "      <th>airplane_code</th>\n",
       "      <th>model_ru</th>\n",
       "      <th>model_en</th>\n",
       "      <th>range</th>\n",
       "      <th>speed</th>\n",
       "    </tr>\n",
       "  </thead>\n",
       "  <tbody>\n",
