       "</table>\n",
       "</div>"
      ],
      "text/plain": [
       "  airplane_code        model_ru         model_en range speed\n",
       "0           35X   Аэробус A350F    Aerobus A350F  8700   903\n",
       "1           76F  Боинг 767-300F  Boeing 767-300F  6000   850"
      ]
     },
     "execution_count": 20,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "conn = sqlite3.connect(\"demo.sqlite\")\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT\n",
    "    a.airplane_code,\n",
    "    json_extract(a.model, '$.ru') AS model_ru,\n",
    "    json_extract(a.model, '$.en') AS model_en,\n",
    "    a.range,\n",
    "    a.speed\n",
    "FROM airplanes_data a\n",
    "LEFT JOIN routes r ON r.airplane_code = a.airplane_code\n",
    "LEFT JOIN flights f ON f.route_no = r.route_no\n",
    "WHERE f.flight_id IS NULL;\n",
    "\"\"\"\n",
    "\n",
    "result_df = pd.read_sql_query(query, conn)\n",
    "conn.close()\n",
    "\n",
    "result_df"
   ]
  },
  {
   "cell_type": "code",
